meta {
  name: add new product
  type: http
  seq: 2
}

post {
  url: http://localhost:50000/products
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer -colocar_token-
}

body:json {
  {
    "name": "Cemento 1kg",
    "price": 1200,
    "stock": 800,
    "category": "Materiales"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
